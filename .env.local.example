# ─────────────────────────────────────────────────────────────────
# Wattfull — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────

# Neon Postgres connection string
# Create a free project at https://neon.tech → Settings → Connection Details
# Use the "Pooled connection" string (ends in ?sslmode=require)
DATABASE_URL="postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/wattfull?sslmode=require"

# Admin panel password — change this in production
ADMIN_PASSWORD="change-me"

# ── STRONGLY RECOMMENDED ──────────────────────────────────────────

# EIA API key — free, takes ~1 min to get
# Register at: https://www.eia.gov/opendata/register.php
# Without this, ingest cron jobs silently skip and the app uses seeded state-level fallback rates.
EIA_API_KEY="your-eia-api-key"

# Secret used by Vercel to authenticate cron job calls to /api/ingest/*
# Generate: openssl rand -hex 16    (or any 32-char random string)
# Without this, the ingest endpoints are unauthenticated (anyone can call them).
CRON_SECRET="generate-a-random-32-char-string"

# ── OPTIONAL ──────────────────────────────────────────────────────

# Resend — transactional email for newsletter welcome messages
# Sign up at https://resend.com (free tier: 3,000 emails/mo)
# Without this, newsletter signups are stored in DB but no welcome email is sent.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="noreply@yourdomain.com"

# Your production domain — used for canonical URLs and sitemap in SEO pages
# Without this, canonical tags in /ev-charging-cost, /cost-to-own, /ev-vs-gas will be empty.
NEXT_PUBLIC_SITE_URL="https://wattfull.com"
